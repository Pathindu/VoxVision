# ── Copy this file to .env and fill in your values ────────────────────────

# PostgreSQL connection string
DATABASE_URL=postgresql://voxvision:voxvision@localhost:5432/voxvision
# JWT – generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=CHANGE_ME_generate_a_real_secret_here
ACCESS_TOKEN_EXPIRE_MINUTES=60

# PayHere credentials (from your PayHere merchant dashboard)
PAYHERE_MERCHANT_ID=
PAYHERE_MERCHANT_SECRET=

# Google Gemini AI
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash-lite

# Google Cloud TTS – path to your service-account JSON key file
GOOGLE_APPLICATION_CREDENTIALS=./google-credentials.json

# Frontend tunnel URL (e.g. ngrok) – added to CORS allowed origins
APP_ORIGINS=http://localhost:3000
